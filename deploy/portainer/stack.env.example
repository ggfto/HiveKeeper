# HiveKeeper — the Portainer stack's environment variables.
#
# Paste these into Portainer -> your stack -> Environment variables, filling in the blanks. Do NOT commit a
# copy with real values: this file is a template and stays one.
#
# Generate the secrets with:
#   openssl rand -base64 32     (keys)
#   openssl rand -hex 24        (passwords — no quoting hazards, they also go into keystores)

# --- Images ---------------------------------------------------------------------------------------------
# Pin the release. Never `latest` in production: an unattended restart would silently upgrade you.
HIVEKEEPER_REGISTRY=ghcr.io/ggfto
HIVEKEEPER_TAG=0.9.0

# --- Where this deployment answers ----------------------------------------------------------------------
# The console. Keycloak is muxed under /auth on this same hostname by the tunnel's path rule, so there is
# one hostname, one DNS record, and no second subdomain just to sign in.
HIVEKEEPER_DOMAIN=hive.example.org

# The agents, as a separate hostname because it is a tcp: ingress rather than an http: one. This name ends
# up in the SAN of the gateway's certificate, so changing it later means regenerating the PKI — which
# orphans every enrolled agent. Choose it once.
HIVEKEEPER_AGENT_DOMAIN=agents.example.org

# --- Cloudflare -----------------------------------------------------------------------------------------
# API token scopes: Account > Cloudflare Tunnel: Edit, and Zone > DNS: Edit on the zone below.
CF_API_TOKEN=
CF_ACCOUNT_ID=
CF_ZONE_ID=
# One tunnel per stack — must be unique within the account.
TUNNEL_NAME=hivekeeper
CLOUDFLARED_VERSION=latest

# --- Secrets --------------------------------------------------------------------------------------------
# Encrypts job secrets and sealed credentials at rest, in the database. BACK IT UP: losing it does not lose
# the data, it makes the data permanently unreadable.
HIVEKEEPER_CRYPTO_KEY=

# The database.
HIVEKEEPER_DB_PASSWORD=
HIVEKEEPER_DB_ADMIN_PASSWORD=

# One password for all three PKI keystores, generated once and never rotated (rotating it would require
# regenerating the stores, which orphans the fleet). pki-init creates them with it; the gateway opens them
# with it.
HIVEKEEPER_PKI_STORE_PASSWORD=

# Keycloak: its own database, and the admin account the gateway uses to create users.
KEYCLOAK_DB_PASSWORD=
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=

# --- Sign in with GitHub (optional) ----------------------------------------------------------------------
# Create a GitHub OAuth App whose Authorization callback URL is EXACTLY:
#   https://<HIVEKEEPER_DOMAIN>/auth/realms/hivekeeper/broker/github/endpoint
# Left empty, sign-in is username + password only.
HIVEKEEPER_GITHUB_CLIENT_ID=
HIVEKEEPER_GITHUB_CLIENT_SECRET=

# --- Backups --------------------------------------------------------------------------------------------
HIVEKEEPER_BACKUP_INTERVAL_HOURS=24
HIVEKEEPER_BACKUP_RETENTION_DAYS=14
