# HiveKeeper agent — copy to `.env` next to agent-compose.yml and fill in.
#
# This machine must be on the same network as your access points. It needs no inbound port and no public
# address: the agent dials out to Cloudflare, and the APs are only ever reached over the LAN.

HIVEKEEPER_REGISTRY=ghcr.io/ggfto
# Pin the SAME version as the gateway.
HIVEKEEPER_TAG=0.9.0
CLOUDFLARED_VERSION=latest

# Must match HIVEKEEPER_AGENT_DOMAIN in the server stack — it is the name in the gateway certificate's SAN.
HIVEKEEPER_AGENT_DOMAIN=agents.example.org

# Cloudflare Access service token for that hostname (Zero Trust > Access > Applications > your app >
# policy with Action = Service Auth). Without it `cloudflared access tcp` attempts an interactive browser
# login and the agent never connects.
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# A stable identity for this agent, unique within the organization. It becomes the CN of the agent's
# certificate, so changing it later means re-enrolling.
HIVEKEEPER_AGENT_ID=site-a-agent

# One-time token from the console: Fleet -> Agents -> Enroll. Spent on first start; the agent renews its own
# certificate over mTLS afterwards, with no token.
HIVEKEEPER_ENROLLMENT_TOKEN=

# Protects the agent's own keystore/truststore. openssl rand -hex 24
HIVEKEEPER_AGENT_STORE_PASSWORD=

# base64 AES-256 key encrypting the credential vault AT REST. openssl rand -base64 32
# Without it the vault is written in plaintext (the agent logs a warning). Back it up somewhere else.
HIVEKEEPER_VAULT_KEY=

# Fleet-wide fallback SSH credentials, used only when a device has no vault entry. Leave the password empty
# to force every device through the vault. These never leave this machine.
HIVEKEEPER_DEFAULT_USER=admin
HIVEKEEPER_DEFAULT_PASSWORD=

# tofu | strict | accept-all. accept-all disables host-key verification — lab only.
HIVEKEEPER_SSH_HOSTKEY=tofu

# --- Automatic updates (opt-in: docker compose --profile autoupdate up -d) ---------------------------------
# The agent auto-updates only when its image TAG moves. Pin HIVEKEEPER_TAG above to a version and it never
# fires; set it to `latest` (or a channel you promote alongside the gateway) to have the agent follow.
HIVEKEEPER_UPDATE_INTERVAL_SECONDS=3600
# How long the agent lets an in-flight job finish on shutdown, and how long the runtime and the updater wait
# for it. GRACE must exceed DRAIN.
HIVEKEEPER_SHUTDOWN_DRAIN_SECONDS=30
HIVEKEEPER_SHUTDOWN_GRACE=45s
# Podman only: point the updater at the Docker-compatible socket.
#   systemctl --user enable --now podman.socket
# CONTAINER_SOCK=/run/user/1000/podman/podman.sock
