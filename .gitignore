# Local compose env (the committed template is .env.example)
.env

# A real agent config: it holds the enrollment token, the vault key and the fallback SSH password. Anchored
# to the repo root (where an operator running docker-compose.agent.yml keeps theirs) so it does NOT also
# ignore the committed image default hive-agent/docker/agent.conf or the template hive-agent/agent.conf.example.
/agent.conf

# Local secrets, keystores, and captured device data — never commit
*.pem
*.key
*.p12
*.jks
*.crt
*.csr
secrets.properties
hivekeeper-backups/
hivekeeper-known_hosts
captures/local/
dev-pki/
test-restore/
test-backups/

# Live-AP exploration dumps (scratch output from scripts/hk-cli-explore.py and the capture command)
captures/
