# Copy to .env and adjust. docker compose reads this automatically. All values have sensible defaults
# baked into the compose files — override only what you need.

# --- Images ------------------------------------------------------------------------------------------
# Where to pull published images from, and which tag. `docker compose up --build` builds from source and
# ignores these; `docker compose pull` uses them.
HIVEKEEPER_REGISTRY=ghcr.io/ggfto
HIVEKEEPER_TAG=latest

# --- Gateway -----------------------------------------------------------------------------------------
HIVEKEEPER_GATEWAY_PORT=8090
# Keep the static service-principal key path on for the simple stack; the keycloak override turns it off.
HIVEKEEPER_TENANTKEY_ENABLED=true

# --- Agent -------------------------------------------------------------------------------------------
HIVEKEEPER_AGENT_ID=hive-agent
# Fleet-wide fallback SSH credentials, resolved locally by the agent (the cloud never sees them).
HIVEKEEPER_DEFAULT_USER=admin
HIVEKEEPER_DEFAULT_PASSWORD=

# --- Postgres override -------------------------------------------------------------------------------
HIVEKEEPER_DB_PASSWORD=app
HIVEKEEPER_DB_ADMIN_PASSWORD=postgres
# Job secrets are encrypted at rest. Set a real key in prod (openssl rand -base64 32) and set the dev-key
# escape hatch to false. For a local stack the insecure dev key (true) is the zero-config default.
HIVEKEEPER_CRYPTO_KEY=
HIVEKEEPER_CRYPTO_ALLOW_INSECURE_DEV_KEY=true

# --- Keycloak override -------------------------------------------------------------------------------
HIVEKEEPER_KEYCLOAK_PORT=8081
# Must match where the browser logs in (see the issuer note in docker-compose.keycloak.yml).
HIVEKEEPER_OIDC_ISSUER=http://localhost:8081/realms/hivekeeper
