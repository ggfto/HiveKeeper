      "username": "owner",
      "email": "owner@acme.test",
      "emailVerified": true,
      "firstName": "Olivia",
      "lastName": "Owner",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "owner",
          "temporary": false
        }
      ]
    },
    {
      "id": "22222222-2222-2222-2222-222222222222",
      "username": "op",
