{
  "name": "hive-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "HiveKeeper web UI (Vite + React) — multi-org control panel for the hive-gateway control plane.",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "sync-docs": "node scripts/sync-docs.mjs",
    "dev": "node scripts/sync-docs.mjs && vite",
    "build": "node scripts/sync-docs.mjs && vite build",
    "preview": "vite preview",
    "test": "node scripts/sync-docs.mjs && vitest run",
    "test:watch": "node scripts/sync-docs.mjs && vitest"
  },
  "dependencies": {
    "@mriqbox/ui-kit": "^4.15.1",
    "@xyflow/react": "^12.11.2",
    "lucide-react": "^1.24.0",
    "mermaid": "^11.16.0",
    "oidc-client-ts": "^3.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^7.18.1",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.3",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.19",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "vite": "^6.0.7",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
